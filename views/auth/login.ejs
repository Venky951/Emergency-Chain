<%- include('../partials/head', { title: 'Login - Emergency Chain' }) %>
</head>

<body class="min-h-screen flex items-center justify-center px-4 text-white">

  <!-- Background Glow -->
  <div class="absolute w-96 h-96 bg-red-500/20 blur-3xl rounded-full top-10 left-10"></div>
  <div class="absolute w-96 h-96 bg-orange-500/10 blur-3xl rounded-full bottom-10 right-10"></div>

  <!-- Login Card -->
  <div class="glass relative z-10 w-full max-w-md rounded-3xl p-8 shadow-2xl">

    <!-- Logo -->
    <div class="text-center mb-8">

      <h1 class="text-4xl font-bold gradient-text mb-2">
        EmergencyChain
      </h1>

      <p class="text-slate-400">
        Login to access emergency services
      </p>

    </div>

    <!-- Login Form -->
    <!-- Error Message -->
    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="bg-red-500/20 border border-red-500 text-red-300 px-4 py-3 rounded-xl mb-6 text-sm">
        <%= errorMessage %>
      </div>
    <% } %>

    <!-- Login Form -->
    <form action="/login" method="POST" class="space-y-6">

      <!-- Email -->
      <div>

        <label class="block mb-2 text-slate-300">
          Email Address
        </label>

        <input
          type="email"
          name="email"
          placeholder="Enter your email"
          value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>"
          class="w-full bg-slate-900/70 border border-slate-700 rounded-xl px-4 py-3 outline-none focus:border-red-500 transition"
          required
        />

      </div>

      <!-- Password -->
      <div>

        <label class="block mb-2 text-slate-300">
          Password
        </label>

        <input
          type="password"
          name="password"
          placeholder="Enter your password"
          class="w-full bg-slate-900/70 border border-slate-700 rounded-xl px-4 py-3 outline-none focus:border-red-500 transition"
          required
        />

      </div>

      <!-- Remember + Forgot -->
      <div class="flex justify-between items-center text-sm">

        <label class="flex items-center gap-2 text-slate-400">

          <input type="checkbox" name="rememberMe" />

          Remember me

        </label>

        <a href="#" class="text-red-400 hover:text-red-500">
          Forgot Password?
        </a>

      </div>

      <!-- Login Button -->
      <button
        type="submit"
        class="w-full bg-gradient-to-r from-red-500 to-orange-500 hover:scale-[1.02] transition duration-300 py-3 rounded-xl font-semibold shadow-lg shadow-red-500/30"
      >
        Login
      </button>

    </form>

    <!-- Divider -->
    <div class="flex items-center gap-4 my-6">

      <div class="h-[1px] bg-slate-700 flex-1"></div>

      <span class="text-slate-500 text-sm">
        OR
      </span>

      <div class="h-[1px] bg-slate-700 flex-1"></div>

    </div>

    <!-- Google Login -->
    <button
      class="w-full glass hover:bg-white/10 transition py-3 rounded-xl font-medium flex items-center justify-center gap-3"
    >

      <img
        src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png"
        class="w-5 h-5"
      />

      Continue with Google

    </button>

    <!-- Signup -->
    <p class="text-center text-slate-400 mt-8">

      Don't have an account?

      <a href="/signup" class="text-red-400 hover:text-red-500 font-medium">
        Signup
      </a>

    </p>

  </div>



</body>
</html>