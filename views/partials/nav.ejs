<body class="text-white min-h-screen bg-slate-950">

  <!-- Navbar -->
  <nav class="flex justify-between items-center px-8 py-6">

    <!-- Logo Section -->
    <div>
      <h1 class="text-3xl font-bold gradient-text">
        EmergencyChain
      </h1>

      <p class="text-slate-400 text-sm">
        Intelligent Emergency Response System
      </p>
    </div>

    <!-- Buttons Section -->
     <% if (!isLoggedIn) { %>
    <div class="flex gap-3">

      <a href="/login"
        class="bg-red-500 hover:bg-red-600 transition px-6 py-3 rounded-xl font-semibold shadow-lg shadow-red-500/30"
      >
        Login
      </a>

      <a href="/signup"
        class="bg-white text-black hover:bg-slate-200 transition px-6 py-3 rounded-xl font-semibold"
      >
        Sign Up
      </a>

    </div>
<% } %>
<% if (isLoggedIn) { %>
    <div class="flex gap-3">

      <a href="/dashboard"
        class="bg-red-500 hover:bg-red-600 transition px-6 py-3 rounded-xl font-semibold shadow-lg shadow-red-500/30"
      >
        Dashboard
      </a>

      <a href="/logout"
        class="bg-white text-black hover:bg-slate-200 transition px-6 py-3 rounded-xl font-semibold"
      >
        Logout
      </a>
      </div>
      <% } %>
  </nav>

</body>